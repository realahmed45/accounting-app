# Frontend Environment Variables

# API Base URL - change this to your backend URL
VITE_API_URL=https://accounting-app-backend-el1a.onrender.com/api

# ── EmailJS (required for invitation & ownership transfer emails) ──
# Get these from https://dashboard.emailjs.com
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_INVITE_TEMPLATE_ID=your_invite_template_id
VITE_EMAILJS_TRANSFER_TEMPLATE_ID=your_transfer_template_id
